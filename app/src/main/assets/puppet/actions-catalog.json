    "pointer_spectateur_droite": [
      {"t": 0.0, "action": "setGaze",       "gx": 0,  "gy": 0, "duration": 0.3},
      {"t": 0.5, "action": "pointForward",  "side": "right",    "duration": 0.4},
      {"t": 2.5, "action": "setArm",        "side": "right", "shoulder": 0, "elbow": 0, "duration": 0.6}
    ],

    "tour_tete_complet": [
