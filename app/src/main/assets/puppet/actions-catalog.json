      {"t": 0.0, "action": "setArm", "side": "right", "shoulder": 0.6, "elbow": 0.4, "duration": 0.4},
      {"t": 2.0, "action": "setArm", "side": "left",  "shoulder": 0.0, "elbow": 0.0, "duration": 0.5},
