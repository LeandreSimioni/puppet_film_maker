<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0400">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Statut -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prêt."
            android:textColor="#ff9800"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

        <!-- ÉTAPE 1 : texte à lire -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. TEXTE"
            android:textColor="#555"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/scriptInput"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="#1a0e00"
            android:textColor="#e8e0d0"
            android:hint="Texte à lire par la marionnette"
            android:textColorHint="#444"
            android:padding="12dp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:scrollbars="vertical"
            android:overScrollMode="always"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnValidate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Créer son"
            android:backgroundTint="#1a2e1a"
            android:textColor="#4caf50"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnCopyForClaude"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Copier pour Claude (script + timestamps)"
            android:backgroundTint="#1a1a2e"
            android:textColor="#90caf9"
            android:enabled="false"
            android:layout_marginBottom="16dp" />

        <!-- ÉTAPE 2 : timeline JSON -->
        <TextView
            android:id="@+id/labelTimeline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. TIMELINE JSON — colle ici le JSON de Claude"
            android:textColor="#555"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/timelineInput"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="#0d1a0d"
            android:textColor="#a5d6a7"
            android:hint="Colle ici la timeline JSON générée par Claude..."
            android:textColorHint="#2a4a2a"
            android:padding="12dp"
            android:gravity="top"
            android:inputType="textMultiLine"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:scrollbars="vertical"
            android:layout_marginBottom="8dp" />

        <!-- ÉTAPE 3 : rendu -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. RENDU"
            android:textColor="#555"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnRender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lancer le rendu → MP4"
            android:backgroundTint="#2e1a00"
            android:textColor="#ff9800"
            android:enabled="false"
            android:layout_marginBottom="24dp" />

        <!-- Réglages -->
        <Button
            android:id="@+id/btnBackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Changer le fond"
            android:backgroundTint="#1a1a1a"
            android:textColor="#444"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnImportIntroCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Case intro  [importer]"
            android:backgroundTint="#1a1a1a"
            android:textColor="#80cbc4"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnImportOutroCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Case finale  [importer]"
            android:backgroundTint="#1a1a1a"
            android:textColor="#80cbc4"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clé API Mistral"
            android:backgroundTint="#1a1a1a"
            android:textColor="#444"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnAutoUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mises à jour : ✓ actives"
            android:backgroundTint="#1a1a1a"
            android:textColor="#444"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Voir logs"
            android:backgroundTint="#1a1a1a"
            android:textColor="#666"
            android:layout_marginBottom="16dp" />

        <!-- Preview marionnette — carré, en bas -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
